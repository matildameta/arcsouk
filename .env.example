# =============================================================
#  Arc Souk — environment variables
#  Copy this file to ".env" and fill in real values.
#  NEVER commit your real .env (it is in .gitignore).
# =============================================================

# ---------- App ----------
NEXT_PUBLIC_SITE_NAME="Arc Souk"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------- Database (Prisma + Postgres, e.g. Neon / Vercel Postgres) ----------
# Get a free Postgres URL from https://neon.tech (or Vercel Storage).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ---------- NextAuth / Auth.js ----------
NEXTAUTH_URL="http://localhost:3000"
# Generate a secret:  openssl rand -base64 32
NEXTAUTH_SECRET=""

# Google OAuth (https://console.cloud.google.com → Credentials → OAuth client)
# Authorized redirect URI: {APP_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---------- Email / SMTP (for one-time login codes) ----------
EMAIL_SERVER_HOST="smtp.example.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="Arc Souk <no-reply@arcsouk.app>"

# ---------- Admin access ----------
# Comma-separated emails that are allowed into /admin. Everyone else is blocked.
ADMIN_EMAILS="you@example.com"

# ---------- Media uploads (Vercel Blob) ----------
# Vercel → Storage → Blob → create store → Read/Write token
BLOB_READ_WRITE_TOKEN=""

# ---------- Circle Arc Testnet (USDC payments) ----------
NEXT_PUBLIC_ARC_RPC_URL="https://rpc.testnet.arc.network"
NEXT_PUBLIC_ARC_CHAIN_ID="5042002"
NEXT_PUBLIC_ARC_EXPLORER="https://testnet.arcscan.app"
# USDC ERC-20 token contract address on Arc Testnet (read from the official docs / faucet).
NEXT_PUBLIC_USDC_ADDRESS=""
# Where buyers send USDC. Option A: your receiving wallet. Option B: escrow contract address.
NEXT_PUBLIC_PAYMENT_ADDRESS=""
# Optional: WalletConnect Cloud project id (https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=""
